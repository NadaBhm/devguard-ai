output "service_name" {
  description = "Name of the deployed ECS service"
  value       = aws_ecs_service.app.name
}

output "task_definition_arn" {
  description = "ARN of the ECS task definition"
  value       = aws_ecs_task_definition.app.arn
}

output "service_url_hint" {
  description = "Cluster the service was deployed into (attach a load balancer for a public URL)"
  value       = data.aws_ecs_cluster.this.cluster_name
}

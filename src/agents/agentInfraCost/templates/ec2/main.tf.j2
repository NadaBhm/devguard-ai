terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

resource "aws_instance" "this" {
  count         = {{ instance_count }}
  ami           = "{{ ami_id }}"
  instance_type = "{{ instance_type }}"
  key_name      = "{{ key_pair_name }}"

  tags = {
    Name = "{{ instance_name }}"
  }
}

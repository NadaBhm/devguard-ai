variable "region" {
  description = "AWS region to deploy into"
  type        = string
  default     = "{{ region | hcl_string }}"
}

variable "environment" {
  description = "Deployment environment name"
  type        = string
  default     = "{{ environment | hcl_string }}"
}

variable "vpc_id" {
  description = "VPC to deploy the EC2 fleet into"
  type        = string
}

variable "subnet_id" {
  description = "Subnet to deploy the EC2 fleet into"
  type        = string
}

# DevGuard AI - Backend (FastAPI + LangGraph orchestrator)
FROM python:3.12-slim

WORKDIR /app

# System deps needed by some scanners/tools used by CodeSec/DeployOps later
# (git for repo cloning, curl for healthchecks/debugging)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-dev.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/

EXPOSE 8000

# NOTE: entrypoint path assumes Oussema's backend app object lives at
# src/subgroup2/backend/main.py as "app" (per the CDC folder tree,
# section 8). Adjust if the actual module path differs once T-1.2 lands.
CMD ["uvicorn", "src.subgroup2.backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

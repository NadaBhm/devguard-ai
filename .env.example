# =============================================================================
# DevGuard AI - Environment Variables Example
# Copy this file to .env and fill in real values. Never commit the real .env.
# =============================================================================

# --- PostgreSQL (T-1.3) ---
POSTGRES_USER=devguard
POSTGRES_PASSWORD=devguard
POSTGRES_DB=devguard
POSTGRES_PORT=5432

# --- Redis (T-1.4) ---
REDIS_PORT=6379

# --- Qdrant (T-1.11) ---
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Backend / Frontend ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- API auth (T-1.5) ---
API_KEY=change-me-in-real-env

# --- LLM providers (Orchestrator chat, RAG, US-2.2.5) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- AWS (InfraCost / DeployOps agents, Sprint 2+) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- Misc ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# DevGuard AI - Frontend (React 19 + Vite + Tailwind)
# Dev-mode Dockerfile: runs the Vite dev server with hot reload.
# A separate multi-stage production build (nginx-served static build)
# should be added later (Sprint 5, T-5.12 platform deployment).
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
